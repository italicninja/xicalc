# ── Server ──────────────────────────────────────────────
# Railway injects PORT automatically; default for local dev is 3000.
PORT=3000

# ── Database ────────────────────────────────────────────
# Path to the SQLite file. Locally this lives under ./data.
# On Railway, point this at a mounted Volume so it survives redeploys,
# e.g. DATABASE_PATH=/data/xicalc.db
DATABASE_PATH=./data/xicalc.db

# ── Data ingest (LandSandBoat) ──────────────────────────
# Comma-separated content_tag values to keep, matching the server's era.
# Empty string = base game (no expansion tag). HorizonXI is a 75-cap era server.
ERA_CONTENT_TAGS=,COP,TOAU,WOTG,RoZ
# Override the raw .sql sources if needed (defaults point at LandSandBoat `base`).
# LSB_ITEM_URL=
# LSB_RECIPE_URL=

# ── PSXI auction-house scraper ──────────────────────────
PSXI_SCRAPE_ENABLED=true
# Cron expression (node-cron). Default: every hour at minute 7.
PSXI_SCRAPE_CRON=7 * * * *
# HorizonXI is the default PSXI server slug.
PSXI_SERVER=horizonxi

# ── Admin endpoints ─────────────────────────────────────
# Token required (Bearer) to trigger /api/admin/seed and /api/admin/scrape.
# Leave empty to disable the admin endpoints entirely.
ADMIN_TOKEN=
