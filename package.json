{
  "name": "xicalc",
  "version": "1.0.0",
  "description": "FFXI (HorizonXI) crafting profit calculator — Express + SQLite, seeded from LandSandBoat data with PSXI auction-house prices.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
